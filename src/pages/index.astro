---
import Layout from '../layouts/Layout.astro';

const phone = '(949) 989-4980';
const phoneHref = 'tel:+19499894980';

const services = [
	{ icon: '🧊', name: 'Refrigerator Repair', desc: 'Cooling issues, leaks, ice maker & compressor repairs.' },
	{ icon: '🌀', name: 'Washer Repair', desc: 'Drainage, spin cycle, leaks, and motor issues fixed fast.' },
	{ icon: '🔥', name: 'Dryer Repair', desc: 'No heat, no spin, noisy drums and vent service.' },
	{ icon: '🍽️', name: 'Dishwasher Repair', desc: 'Drainage, leaks, poor cleaning, and pump replacement.' },
	{ icon: '🍳', name: 'Oven & Stove Repair', desc: 'Gas & electric ranges, burners, igniters and elements.' },
	{ icon: '📡', name: 'Microwave Repair', desc: 'Built-in & countertop microwaves, no heat, sparking.' }
];

const features = [
	{ icon: '🛡️', title: 'Licensed & Insured', desc: 'Fully certified and insured technicians you can trust.' },
	{ icon: '⚡', title: 'Same-Day Service', desc: 'Most repairs completed the same day you call.' },
	{ icon: '💲', title: 'Fair, Upfront Pricing', desc: 'No hidden fees. You approve the price before we start.' },
	{ icon: '✅', title: 'Warranty on Repairs', desc: 'Every repair backed by our parts & labor warranty.' }
];

const areas = ['Los Angeles', 'Santa Monica', 'Beverly Hills', 'Pasadena', 'Burbank', 'Glendale', 'Long Beach'];
---

<Layout
	title="Appliance Repair Los Angeles | Same-Day Service | (949) 989-4980"
	description="Professional appliance repair in Los Angeles. Same-day service for refrigerators, washers, dryers, dishwashers, ovens & microwaves. Licensed, insured, warrantied. Call (949) 989-4980."
>
	<main class="flex-1">
		<!-- Hero -->
		<section class="relative overflow-hidden">
			<div class="absolute inset-0 bg-gradient-to-br from-purple-900/40 via-[#13151a] to-[#13151a]"></div>
			<div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(124,58,237,0.25),transparent_60%)]"></div>
			<div class="relative max-w-7xl mx-auto px-4 py-16 md:py-24 grid md:grid-cols-2 gap-12 items-center">
				<div>
					<p class="inline-block bg-purple-600/20 text-purple-300 px-3 py-1 rounded-full text-sm font-semibold mb-4">
						⚡ Same-Day Service · Los Angeles
					</p>
					<h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
						Professional <span class="bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">Appliance Repair</span> in Los Angeles
					</h1>
					<p class="text-lg md:text-xl text-gray-300 mb-8">
						Fast, reliable repair for refrigerators, washers, dryers, dishwashers, ovens and microwaves. Licensed technicians. Honest pricing. Warranty included.
					</p>
					<div class="flex flex-col sm:flex-row gap-4">
						<a href={phoneHref} class="bg-purple-600 hover:bg-purple-500 transition text-white font-bold text-lg px-6 py-4 rounded-lg text-center shadow-lg shadow-purple-600/30">
							📞 Call {phone}
						</a>
						<a href="#book" class="bg-white text-[#13151a] hover:bg-gray-200 transition font-bold text-lg px-6 py-4 rounded-lg text-center">
							Book Now →
						</a>
					</div>
					<div class="flex flex-wrap gap-6 mt-8 text-sm text-gray-300">
						<span>✅ Licensed & Insured</span>
						<span>⭐ 5-Star Rated</span>
						<span>🛠️ All Major Brands</span>
					</div>
				</div>
				<div class="bg-[#1a1d26] border border-purple-500/30 rounded-2xl p-6 md:p-8 shadow-2xl" id="book">
					<h2 class="text-2xl font-bold mb-2">Book Your Repair</h2>
					<p class="text-gray-400 mb-6">Tell us about your appliance and we'll call you right back.</p>
					<form name="booking" method="POST" data-netlify="true" class="space-y-4">
						<input type="hidden" name="form-name" value="booking" />
						<div>
							<label for="name" class="block text-sm font-medium mb-1">Your Name</label>
							<input id="name" name="name" type="text" required class="w-full bg-[#13151a] border border-gray-700 focus:border-purple-500 rounded-lg px-4 py-3 text-white outline-none" />
						</div>
						<div>
							<label for="phone" class="block text-sm font-medium mb-1">Phone Number</label>
							<input id="phone" name="phone" type="tel" required class="w-full bg-[#13151a] border border-gray-700 focus:border-purple-500 rounded-lg px-4 py-3 text-white outline-none" />
						</div>
						<div>
							<label for="appliance" class="block text-sm font-medium mb-1">Appliance Type</label>
							<select id="appliance" name="appliance" required class="w-full bg-[#13151a] border border-gray-700 focus:border-purple-500 rounded-lg px-4 py-3 text-white outline-none">
								<option value="">Select an appliance</option>
								<option>Refrigerator</option>
								<option>Washer</option>
								<option>Dryer</option>
								<option>Dishwasher</option>
								<option>Oven / Stove</option>
								<option>Microwave</option>
								<option>Other</option>
							</select>
						</div>
						<div>
							<label for="time" class="block text-sm font-medium mb-1">Preferred Time</label>
							<select id="time" name="time" required class="w-full bg-[#13151a] border border-gray-700 focus:border-purple-500 rounded-lg px-4 py-3 text-white outline-none">
								<option value="">Choose a time</option>
								<option>ASAP / Same Day</option>
								<option>Morning (8am–12pm)</option>
								<option>Afternoon (12pm–5pm)</option>
								<option>Evening (5pm–8pm)</option>
							</select>
						</div>
						<button type="submit" class="w-full bg-purple-600 hover:bg-purple-500 transition text-white font-bold text-lg px-6 py-4 rounded-lg shadow-lg shadow-purple-600/30">
							Request Service →
						</button>
						<p class="text-xs text-gray-500 text-center">By submitting, you agree to be contacted about your repair request.</p>
					</form>
				</div>
			</div>
		</section>

		<!-- Services -->
		<section class="py-16 md:py-20 bg-[#0f1117]">
			<div class="max-w-7xl mx-auto px-4">
				<div class="text-center mb-12">
					<h2 class="text-3xl md:text-4xl font-bold mb-3">Appliance Repair Services</h2>
					<p class="text-gray-400 max-w-2xl mx-auto">We repair all major brands and models. Same-day service across Los Angeles.</p>
				</div>
				<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
					{services.map(s => (
						<div class="bg-[#1a1d26] border border-purple-500/20 hover:border-purple-500/60 transition rounded-xl p-6">
							<div class="text-4xl mb-3">{s.icon}</div>
							<h3 class="text-xl font-bold mb-2 text-purple-300">{s.name}</h3>
							<p class="text-gray-400">{s.desc}</p>
						</div>
					))}
				</div>
				<div class="text-center mt-10">
					<a href={phoneHref} class="inline-block bg-purple-600 hover:bg-purple-500 transition text-white font-bold px-6 py-3 rounded-lg">
						📞 Call Now: {phone}
					</a>
				</div>
			</div>
		</section>

		<!-- Why Choose Us -->
		<section class="py-16 md:py-20">
			<div class="max-w-7xl mx-auto px-4">
				<div class="text-center mb-12">
					<h2 class="text-3xl md:text-4xl font-bold mb-3">Why Choose Same Day Appliance Repair</h2>
					<p class="text-gray-400 max-w-2xl mx-auto">Trusted by Los Angeles homeowners for fast, honest, professional service.</p>
				</div>
				<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
					{features.map(f => (
						<div class="bg-gradient-to-br from-purple-900/30 to-[#1a1d26] border border-purple-500/20 rounded-xl p-6 text-center">
							<div class="text-4xl mb-3">{f.icon}</div>
							<h3 class="text-lg font-bold mb-2">{f.title}</h3>
							<p class="text-sm text-gray-400">{f.desc}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Service Areas -->
		<section class="py-16 md:py-20 bg-[#0f1117]">
			<div class="max-w-7xl mx-auto px-4">
				<div class="text-center mb-12">
					<h2 class="text-3xl md:text-4xl font-bold mb-3">Service Areas</h2>
					<p class="text-gray-400">Proudly serving Los Angeles and surrounding communities.</p>
				</div>
				<div class="flex flex-wrap justify-center gap-3 max-w-4xl mx-auto">
					{areas.map(a => (
						<span class="bg-[#1a1d26] border border-purple-500/30 px-5 py-2 rounded-full text-purple-200">
							📍 {a}
						</span>
					))}
				</div>
			</div>
		</section>

		<!-- Final CTA -->
		<section class="py-16 md:py-20">
			<div class="max-w-4xl mx-auto px-4 text-center bg-gradient-to-br from-purple-700 to-purple-900 rounded-2xl p-8 md:p-12 shadow-2xl">
				<h2 class="text-3xl md:text-4xl font-bold mb-4">Need Repair Today?</h2>
				<p class="text-purple-100 text-lg mb-8">Call now for same-day appliance repair anywhere in Los Angeles.</p>
				<a href={phoneHref} class="inline-block bg-white text-purple-700 font-extrabold text-xl md:text-2xl px-8 py-4 rounded-lg hover:bg-gray-100 transition shadow-lg">
					📞 {phone}
				</a>
			</div>
		</section>
	</main>
</Layout>

---
import '../styles/base.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Same Day Appliance Repair Los Angeles | (949) 989-4980',
	description = 'Professional appliance repair in Los Angeles. Same-day service for refrigerators, washers, dryers, dishwashers, ovens & microwaves. Licensed, insured, warrantied. Call (949) 989-4980.'
} = Astro.props;

const phone = '(949) 989-4980';
const phoneHref = 'tel:+19499894980';
const businessName = 'Same Day Appliance Repair';
const siteUrl = 'https://appliancerepairdaily.com';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={siteUrl} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={siteUrl} />
		<meta property="og:site_name" content={businessName} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />

		<title>{title}</title>

		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "LocalBusiness",
			"@id": siteUrl + "#business",
			"name": businessName,
			"image": siteUrl + "/favicon.svg",
			"url": siteUrl,
			"telephone": "+19499894980",
			"priceRange": "$$",
			"address": {
				"@type": "PostalAddress",
				"addressLocality": "Los Angeles",
				"addressRegion": "CA",
				"addressCountry": "US"
			},
			"areaServed": [
				"Los Angeles", "Santa Monica", "Beverly Hills", "Pasadena", "Burbank", "Glendale", "Long Beach"
			],
			"openingHoursSpecification": [{
				"@type": "OpeningHoursSpecification",
				"dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
				"opens": "07:00",
				"closes": "21:00"
			}],
			"sameAs": []
		})} />

		<script src="https://analytics.ahrefs.com/analytics.js" data-key="s7QI57LsrItr4I9CZh+Vgw" async></script>
	</head>
	<body class="bg-[#13151a] text-white min-h-screen flex flex-col">
		<header class="sticky top-0 z-50 bg-[#1a1d26]/95 backdrop-blur border-b border-purple-500/20">
			<div class="bg-[#7c3aed] text-white text-center py-2 text-sm font-medium">
				⚡ Same-Day Service Available · Book Online & Save $35
			</div>
			<nav class="max-w-7xl mx-auto px-4 flex justify-between items-center py-4 gap-4">
				<a href="/" class="text-xl md:text-2xl font-bold">
					<span class="text-white">Same Day</span>
					<span class="text-purple-400">Appliance Repair</span>
				</a>
				<a href={phoneHref} class="bg-purple-600 hover:bg-purple-500 transition px-4 py-2 rounded-lg font-bold text-white whitespace-nowrap">
					📞 {phone}
				</a>
			</nav>
		</header>

		<slot />

		<footer class="bg-[#0f1117] border-t border-purple-500/20 text-white py-10 mt-auto">
			<div class="max-w-7xl mx-auto px-4 text-center space-y-3">
				<a href={phoneHref} class="inline-block text-2xl font-bold text-purple-400 hover:text-purple-300">
					📞 {phone}
				</a>
				<p class="text-gray-400">Same-Day Appliance Repair · Los Angeles & Surrounding Areas</p>
				<p class="text-sm text-gray-500">&copy; {new Date().getFullYear()} {businessName}. All rights reserved.</p>
			</div>
		</footer>
	</body>
</html>
